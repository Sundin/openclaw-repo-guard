{
  "name": "repo-guard",
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "check:syntax": "node --check index.js && node --check lib/repo-guard-core.js",
    "test:deterministic": "node --test test/*.test.mjs",
    "ci": "npm run check:syntax && npm run test:deterministic"
  },
  "openclaw": {
    "extensions": ["./index.js"],
    "hooks": {
      "before_tool_call": {
        "source": "./index.js"
      }
    },
    "compat": {
      "pluginApi": ">=2026.4.2",
      "minGatewayVersion": "2026.4.2"
    },
    "build": {
      "openclawVersion": "2026.4.2",
      "pluginSdkVersion": "2026.4.2"
    }
  }
}
